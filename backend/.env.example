# ──────────────────────────────────────────────
# BACKEND — .env (modelo COMPLETO)
# Copie para .env e preencha com valores reais.
# ──────────────────────────────────────────────

# === Supabase ===
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx.yyyyy
# (opcional, usado pelo /api/security-check para validar RLS):
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx.yyyyy

# === Flask ===
# Gere com: openssl rand -hex 32
FLASK_SECRET_KEY=troque_por_uma_string_de_ao_menos_32_caracteres_xxxxxx
FLASK_ENV=production

# === URLs / CORS ===
FRONTEND_URL=https://seu-app.vercel.app
ALLOWED_ORIGINS=https://seu-app.vercel.app,http://localhost:3000

# === Stripe (Payments) ===
# Dashboard: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxx
# Webhooks → criar endpoint /api/stripe/webhook e copiar o whsec_...:
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# === Stripe Connect (payouts para compositores) ===
# Habilite em: https://dashboard.stripe.com/settings/connect
# (a chave secreta acima já cobre a API, basta ativar Connect/Express)

# === PayPal ===
# Dashboard: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx
PAYPAL_MODE=sandbox        # use 'live' em produção

# === Redis (rate-limit em produção) ===
# Sem isso, o limite de requisições roda em memória e NÃO funciona
# corretamente com mais de 1 worker do Gunicorn.
REDIS_URL=redis://default:senha@host:6379

# === Criptografia de PII (CPF/CNPJ) ===
# 32 bytes em base64. Gere com:
#   python -c "import secrets, base64; print(base64.urlsafe_b64encode(secrets.token_bytes(32)).decode())"
PII_ENCRYPTION_KEY=substituir_por_chave_base64_de_32_bytes

# === Dados bancários da PITCH.ME ===
# Usados para preencher a cláusula de fee 5% nos contratos de editora.
# Estes valores também são salvos em landing_content via seed_contrato_edicao.sql.
PITCHME_BANCO=
PITCHME_AGENCIA=
PITCHME_CONTA=
PITCHME_TITULAR=PITCH.ME
PITCHME_CNPJ=
